generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ENUMS (Sincronizados con imágenes de Supabase)
// ============================================

enum EstadoPedido {
  pendiente
  corte
  costura
  acabado
  completado
  cancelado
}

enum EstadoConfeccion {
  pendiente
  corte
  confeccionando
  remallado
  terminado
}

enum EstadoDespacho {
  pendiente
  en_ruta
  entregado
}

enum rol {
  administrador
  cortador
  diseñador
  recepcionista
  ayudante
  representante_taller
}

enum EstadoUsuario {
  activo
  inactivo
  suspendido
}

enum PrioridadPedido {
  baja
  normal
  alta
  urgente
}

enum EstadoProducto {
  activo
  inactivo
  agotado
  descontinuado
}

enum EspecialidadTaller {
  corte
  confeccion
  bordado
  estampado
  costura
  acabados
  otro
}

enum EstadoTaller {
  activo
  inactivo
  suspendido
}

enum EstadoPago {
  pendiente
  pagado_parcial
  pagado
  vencido
}

enum EstadoOrden {
  solicitado
  cotizado
  aprobado
  pagado
  en_proceso
  finalizado
  cancelado
}

enum TipoComprobante {
  boleta
  factura
  nota_venta
}

// Nota: TallaProductos en tu imagen es un tipo de dato, 
// pero usualmente se maneja como String o Enum personalizado en modelos.
enum TallaProductos {
  XS
  S
  M
  L
  XL
  XXL
  N28 // Prisma no permite números al inicio del enum
  N30
  N32
  N34
  @@map("TallaProductos")
}

enum MetodoPago {
  efectivo
  transferencia_bcp
  yape
  plin
  visa
  mastercard
}

enum EstadoCliente {
  activo
  inactivo
  suspendido
  potencial
}

enum UnidadMedida {
  metros
  unidades
  conos
  docenas
  kilogramos
  set
}

enum TipoInsumo {
  tela
  hilo
  avio
  boton
  cierre
}

enum EstadoCotizacion {
  pendiente
  aceptada
  rechazada
  expirada
}

enum TipoCliente {
  corporativo
  minorista
  distribuidor
}

enum TipoCategoria {
  producto
  insumo
}

enum EstadoCategoria {
  activo
  inactivo
}

enum ColorPrenda {
  Blanco
  Negro
  Gris
  Beige
  Marron_pastel // Prisma no permite espacios
  Azul_jean
  Azul_marino
  Rojo
  Rosa_pastel
  Morado_claro
  Verde_olivo
  Amarillo
  Naranja
  Multicolor
  Unico
  Vino
  Camel
  Crema
  Celeste
  Amarillo_limon
  @@map("ColorPrenda")
}

enum TipoMovimiento {
  entrada
  salida
  ajuste
}

// ============================================
// MODELOS
// ============================================

model categorias {
  id          BigInt    @id @default(autoincrement())
  nombre      String    @unique
  descripcion String?
  created_at  DateTime  @default(now())
  updated_at  DateTime? @default(now()) @updatedAt
  orden       BigInt?
  activo      Boolean?  @default(true)
  imagen      String?
  
  productos   productos[]
  inventario  inventario[]

  @@map("categorias")
}

model clientes {
  id           BigInt         @id @default(autoincrement())
  ruc          BigInt
  razon_social String?
  email        String?
  telefono     BigInt?
  direccion    String?
  tipo         TipoCliente    @default(minorista)
  activo       EstadoCliente  @default(activo)
  created_at   DateTime       @default(now())
  updated_at   DateTime       @default(now()) @updatedAt
  auth_id      String?        @unique @db.Uuid

  pedidos pedidos[]

  @@map("clientes")
}

model usuarios {
  id              BigInt         @id @default(autoincrement())
  email           String         @unique
  nombre_completo String
  telefono        String?
  estado          EstadoUsuario  @default(activo)
  rol             rol            @default(ayudante)
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt
  auth_id         String?        @unique @db.Uuid
  ultimo_acceso   DateTime?
  avatar_url      String?
  created_by      String?        @db.Uuid

  despachos despachos[]

  @@map("usuarios")
}

model productos {
  id           BigInt         @id @default(autoincrement())
  nombre       String
  descripcion  String?
  created_at   DateTime       @default(now())
  categoria_id BigInt
  imagen       String?
  precio       Float
  stock        Int            @default(0)
  stock_minimo Int            @default(0)
  updated_at   DateTime       @updatedAt
  estado       EstadoProducto @default(activo)
  sku          String         @unique

  categoria        categorias           @relation(fields: [categoria_id], references: [id])
  detalles_pedido  detalles_pedido[]
  variantes        variantes_producto[]
  lista_materiales lista_materiales[]
  inventario       inventario[]

  @@map("productos")
}

model pedidos {
  id                       BigInt           @id @default(autoincrement())
  cliente_id               BigInt?
  fecha_pedido             DateTime?        @default(now())
  fecha_entrega_estimada   DateTime?
  estado                   EstadoPedido?    @default(pendiente)
  prioridad                PrioridadPedido? @default(normal)
  total                    Decimal          @db.Decimal(10, 2)
  notas                    String?
  direccion_envio          String?
  created_at               DateTime         @default(now())
  updated_at               DateTime?        @updatedAt
  orden_id                 String?          @unique
  metodo_pago              String?
  
  cliente                  clientes?        @relation(fields: [cliente_id], references: [id])
  detalles                 detalles_pedido[]

  @@map("pedidos")
}

model detalles_pedido {
  id              BigInt   @id @default(autoincrement())
  pedido_id       BigInt
  producto_id     BigInt
  cantidad        Int
  talla           String
  color           String?
  precio_unitario Decimal  @db.Decimal(10, 2)
  subtotal        Decimal  @db.Decimal(10, 2)
  created_at      DateTime @default(now())
  
  pedido          pedidos   @relation(fields: [pedido_id], references: [id])
  producto        productos @relation(fields: [producto_id], references: [id])

  @@map("detalles_pedido")
}

model variantes_producto {
  id               BigInt      @id @default(autoincrement())
  producto_id      BigInt?
  nombre           String
  talla            String?
  color            String?
  precio_adicional Decimal?    @default(0) @db.Decimal(10, 2)
  stock_adicional  Int?        @default(0)
  sku              String?     @unique
  activo           Boolean?    @default(true)
  created_at       DateTime?   @default(now())
  updated_at       DateTime?   @default(now()) @updatedAt
  
  producto         productos?  @relation(fields: [producto_id], references: [id])

  @@map("variantes_producto")
}

model talleres {
  id           BigInt             @id @default(autoincrement())
  nombre       String
  direccion    String
  telefono     String
  email        String?
  ruc          String             @unique
  contacto     String
  estado       EstadoTaller       @default(activo)
  created_at   DateTime           @default(now())
  updated_at   DateTime           @updatedAt
  confecciones confecciones[]

  @@map("talleres")
}

model confecciones {
  id            BigInt            @id @default(autoincrement())
  pedido_id     BigInt
  taller_id     BigInt
  estado        EstadoConfeccion  @default(pendiente)
  fecha_inicio  DateTime          @default(now())
  fecha_fin     DateTime?
  observaciones String?
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt
  
  taller        talleres          @relation(fields: [taller_id], references: [id])

  @@map("confecciones")
}

model despachos {
  id                BigInt          @id @default(autoincrement())
  pedido_id         BigInt
  usuario_id        BigInt
  estado            EstadoDespacho  @default(pendiente)
  direccion_entrega String
  fecha_despacho    DateTime        @default(now())
  fecha_entrega     DateTime?
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt
  
  usuario           usuarios        @relation(fields: [usuario_id], references: [id])

  @@map("despachos")
}

model inventario {
  id             BigInt        @id @default(autoincrement())
  sku            String?       @unique
  nombre         String
  tipo           TipoInsumo
  unidad_medida  UnidadMedida  @default(unidades)
  stock_actual   Int           @default(0)
  stock_minimo   Int           @default(10)
  costo_unitario Decimal?      @db.Decimal(10, 2)
  precio_venta   Decimal?      @db.Decimal(10, 2)
  categoria_id   BigInt?
  producto_id    BigInt?
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt
  
  categoria      categorias?   @relation(fields: [categoria_id], references: [id])
  producto       productos?    @relation(fields: [producto_id], references: [id])
  lista_materiales lista_materiales[]

  @@map("inventario")
}

model lista_materiales {
  id                 BigInt     @id @default(autoincrement())
  producto_id        BigInt?
  insumo_id          BigInt?
  cantidad_requerida Float?
  created_at         DateTime   @default(now())
  updated_at         DateTime?  @updatedAt
  
  producto           productos? @relation(fields: [producto_id], references: [id])
  insumo             inventario? @relation(fields: [insumo_id], references: [id])

  @@map("lista_materiales")
}