generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "public"]
}


// VENTAS


model cotizaciones {
  id                   BigInt      @id @default(autoincrement())
  numero               String      @unique
  pedido_id            BigInt?
  cliente_id           BigInt?
  estado               String?     @default("borrador")
  subtotal             Decimal?    @default(0) @db.Decimal(12, 2)
  igv                  Decimal?    @default(0) @db.Decimal(12, 2)
  total                Decimal?    @default(0) @db.Decimal(12, 2)
  valida_hasta         DateTime    @db.Date
  // Cotización Express
  expira_at            DateTime?   @db.Timestamptz(6)  // Expiración real del quote
  aprobado_at          DateTime?   @db.Timestamptz(6)  // Timestamp de aprobación
  aprobacion_automatica Boolean?   @default(false)     // Aprobación automática al pagar
  created_at           DateTime?   @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?   @default(now()) @db.Timestamptz(6)
  metodo_pago          MetodoPago?
  direccion_despacho   String?
  id_regla_descuento   BigInt?
  monto_descuento      Decimal?    @default(0) @db.Decimal(12, 2)
  costo_envio          Decimal?    @default(0) @db.Decimal(12, 2)
  moneda               String      @default("PEN") @db.VarChar(3)
  costo_total_estimado Decimal?    @default(0) @db.Decimal(12, 2)
  notas_internas       String?

  cotizacion_items cotizacion_items[]
  clientes         clientes?          @relation(fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reglas_descuento reglas_descuento?  @relation(fields: [id_regla_descuento], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pedidos          pedidos?           @relation(fields: [pedido_id], references: [id], onUpdate: NoAction)
  ordenes          ordenes[]

  @@schema("public")
}

model cotizacion_items {
  id                       BigInt              @id @default(autoincrement())
  cotizacion_id            BigInt?
  producto_id              BigInt?
  variante_id              BigInt?
  cantidad                 Int
  precio_unitario_snapshot Decimal             @db.Decimal(12, 2)
  subtotal                 Decimal             @db.Decimal(12, 2)
  cotizaciones             cotizaciones?       @relation(fields: [cotizacion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  productos                productos?          @relation(fields: [producto_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  variantes_producto       variantes_producto? @relation(fields: [variante_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model ordenes {
  id                      BigInt        @id @default(autoincrement())
  cotizacion_id           BigInt?
  cliente_id              BigInt?
  proveedor_id            BigInt?       // Proveedor asociado (órdenes de compra)
  user_id                 String?       @db.Uuid
  estado                  EstadoOrden?  @default(solicitado)
  metodo_pago             MetodoPago?
  // Campos de control financiero
  total_orden             Decimal       @default(0) @db.Decimal(12, 2)
  total_pagado            Decimal?      @default(0) @db.Decimal(12, 2)
  saldo_pendiente         Decimal?      @default(0) @db.Decimal(12, 2)
  // Campos operativos
  created_at              DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at              DateTime?     @default(now()) @db.Timestamptz(6)
  fecha_prometida_entrega DateTime?     @db.Date
  estado_pago             String?       @default("pendiente")
  prioridad               String?       @default("media")
  costo_envio_real        Decimal?      @default(0) @db.Decimal(12, 2)
  // KPIs de tiempo — flujo de producción
  enviado_taller_at       DateTime?     @db.Timestamptz(6)  // Cuando se manda a producción
  recibido_taller_at      DateTime?     @db.Timestamptz(6)  // Cuando el taller confirma recepción
  entregado_cliente_at    DateTime?     @db.Timestamptz(6)  // Cuando se entrega al cliente
  // Relaciones
  cliente                 clientes?          @relation(fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cotizaciones            cotizaciones?      @relation(fields: [cotizacion_id], references: [id], onUpdate: NoAction)
  proveedores             proveedores?       @relation(fields: [proveedor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                   users?             @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pagos_orden             pagos_orden[]
  ventas                  ventas[]
  asientos_contables      asientos_contables[]
  reservas_stock          reservas_stock[]
  feedback_cliente        feedback_cliente[]
  estados_produccion      estados_produccion[]
  incidencias_taller      incidencias_taller[]

  @@schema("public")
}

model pagos_orden {
  id              BigInt      @id @default(autoincrement())
  orden_id        BigInt
  monto           Decimal     @db.Decimal(12, 2)
  metodo_pago     MetodoPago
  fecha_pago      DateTime    @default(now()) @db.Timestamptz(6)
  comprobante_url String?     // Foto del voucher o recibo
  notas           String?
  usuario_id      BigInt?     // Usuario que registró el pago
  created_at      DateTime    @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?   @default(now()) @db.Timestamptz(6)
  // Relaciones
  ordenes         ordenes     @relation(fields: [orden_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuarios        usuarios?   @relation("usuario_pagos", fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  asientos_contables asientos_contables[]

  @@index([orden_id], map: "idx_pagos_orden_link")
  @@index([fecha_pago(sort: Desc)], map: "idx_pagos_fecha")
  @@schema("public")
}

model ventas_anuladas {
  id               BigInt   @id @default(autoincrement())
  venta_id         String   @unique @db.Uuid
  motivo           String
  fecha_anulacion  DateTime @default(now())
  monto_devuelto   Decimal  @db.Decimal(12, 2)
  ventas           ventas   @relation(fields: [venta_id], references: [id])

  @@schema("public")
}

model ventas {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orden_id           BigInt
  vendedor_id        String?          @default(dbgenerated("uid()")) @db.Uuid
  usuario_id         BigInt?          // Usuario que registró la venta (auditoría)
  subtotal           Decimal          @default(0) @db.Decimal(12, 2)
  impuestos          Decimal          @default(0) @db.Decimal(12, 2)
  total              Decimal          @default(0) @db.Decimal(12, 2)
  metodo_pago        MetodoPago?
  numero_comprobante String?
  created_at         DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?        @default(now()) @db.Timestamptz(6)
  tipo_comprobante   TipoComprobante?
  // Relaciones
  vendedor           users?           @relation(fields: [vendedor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuarios           usuarios?        @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ordenes            ordenes          @relation(fields: [orden_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  referencia_pago    String?          @db.VarChar(255) // ID de la pasarela
  estado_pago        String           @default("completado") // completado, reembolsado, parcial
  ventas_anuladas    ventas_anuladas? // Relación para Notas de Crédito
  asientos_contables asientos_contables[]

  @@index([created_at(sort: Desc)], map: "idx_ventas_fecha_pago")
  @@index([orden_id], map: "idx_ventas_orden_link")
  @@schema("public")
}

model asientos_contables {
  id                BigInt          @id @default(autoincrement())
  fecha             DateTime        @default(now()) @db.Timestamptz(6)
  tipo              TipoAsiento     // DEBE o HABER
  monto             Decimal         @db.Decimal(12, 2)
  cuenta            CuentaContable  // Cuenta contable afectada
  descripcion       String?         // Detalle del asiento
  // Referencias a transacciones origen
  orden_id          BigInt?
  venta_id          String?         @db.Uuid
  pago_id           BigInt?
  // Relaciones bidireccionales
  ordenes           ordenes?        @relation(fields: [orden_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ventas            ventas?         @relation(fields: [venta_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pagos_orden       pagos_orden?    @relation(fields: [pago_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  // Auditoría
  usuario_id        BigInt?
  created_at        DateTime        @default(now()) @db.Timestamptz(6)

  @@index([fecha(sort: Desc)], map: "idx_asientos_fecha")
  @@index([orden_id], map: "idx_asientos_orden")
  @@index([venta_id], map: "idx_asientos_venta")
  @@index([cuenta], map: "idx_asientos_cuenta")
  @@schema("public")
}

model comprobantes {
  id          BigInt    @id @default(autoincrement())
  orden_id    BigInt
  tipo        String
  serie       String
  correlativo String
  pdf_url     String?
  xml_url     String?
  emitido_en  DateTime? @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

model pedido_items {
  id                 BigInt              @id @default(autoincrement())
  pedido_id          BigInt?
  producto_id        BigInt?
  variante_id        BigInt?
  cantidad           Int
  especificaciones   Json?
  pedidos            pedidos?            @relation(fields: [pedido_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  productos          productos?          @relation(fields: [producto_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  variantes_producto variantes_producto? @relation(fields: [variante_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}


// ============================================================
//  PRODUCCIÓN — Pedidos, Confecciones, Talleres, Despachos
//  + Incidencias de Taller
//  + Estados de Producción (tracking por etapa)
//  + Feedback de Cliente
//  + Fichas Técnicas
// ============================================================

model pedidos {
  id             BigInt           @id @default(autoincrement())
  cliente_id     BigInt?
  estado         EstadoPedido?    @default(pendiente)
  prioridad      PrioridadPedido? @default(normal)
  notas_cliente  String?
  created_by     String?          @default(dbgenerated("uid()")) @db.Uuid
  created_at     DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?        @default(now()) @db.Timestamptz(6)
  notas_pedido   String?
  total_estimado Decimal?         @default(0) @db.Decimal(12, 2)
  total_unidades Int              @default(0)
  moq_aplicado   Int              @default(400)
  cotizaciones   cotizaciones[]
  pedido_items   pedido_items[]
  confecciones   confecciones[]
  despachos      despachos[]
  clientes       clientes?        @relation(fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users          users?           @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model confecciones {
  id            BigInt           @id @default(autoincrement())
  pedido_id     BigInt
  taller_id     BigInt
  estado        EstadoConfeccion @default(corte)
  fecha_inicio  DateTime         @db.Timestamptz(6)
  fecha_fin     DateTime?        @db.Timestamptz(6)
  observaciones String?
  created_at    DateTime         @default(now()) @db.Timestamptz(6)
  updated_at    DateTime         @default(now()) @db.Timestamptz(6)
  responsable_id BigInt?         // Usuario asignado (cortador, jefe taller)
  // Relaciones
  pedido        pedidos          @relation(fields: [pedido_id], references: [id])
  taller        talleres         @relation(fields: [taller_id], references: [id])
  responsable   usuarios?        @relation(fields: [responsable_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  incidencias_taller incidencias_taller[]

  @@index([pedido_id], map: "idx_confecciones_pedido")
  @@index([responsable_id], map: "idx_confecciones_responsable")
  @@schema("public")
}

model talleres {
  id           BigInt              @id @default(autoincrement())
  nombre       String
  direccion    String
  telefono     String
  email        String?             @unique
  created_at   DateTime            @default(now()) @db.Timestamptz(6)
  updated_at   DateTime            @default(now()) @db.Timestamptz(6)
  ruc          String              @unique
  contacto     String
  especialidad EspecialidadTaller?
  estado       EstadoTaller        @default(activo)
  confecciones confecciones[]

  @@schema("public")
}

model despachos {
  id                BigInt         @id @default(autoincrement())
  pedido_id         BigInt
  fecha_despacho    DateTime
  created_at        DateTime       @default(now())
  direccion_entrega String
  fecha_entrega     DateTime?
  updated_at        DateTime       @default(now())
  usuario_id        BigInt
  estado            EstadoDespacho @default(pendiente)
  // Relaciones
  pedido            pedidos        @relation(fields: [pedido_id], references: [id])
  usuario           usuarios       @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([pedido_id], map: "idx_despachos_pedido")
  @@schema("public")
}

// ============================================================
//  INCIDENCIAS DE TALLER
//  Registro de fallas/obstáculos en producción
// ============================================================
model incidencias_taller {
  id                BigInt              @id @default(autoincrement())
  orden_id          BigInt
  confeccion_id     BigInt?
  tipo              TipoIncidencia
  severidad         SeveridadIncidencia @default(media)
  descripcion       String
  // Registro y resolución
  reportado_por     BigInt?             // Usuario que reporta
  asignado_a        BigInt?             // Usuario responsable de resolver
  fecha_reporte     DateTime            @default(now()) @db.Timestamptz(6)
  fecha_resolucion  DateTime?           @db.Timestamptz(6)
  resuelto          Boolean             @default(false)
  solucion          String?             // Detalle de cómo se resolvió
  impacto_horas     Float?              // Horas de retraso estimadas
  // Evidencia
  foto_url          String?             @db.VarChar(500)
  // Auditoría
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?           @default(now()) @db.Timestamptz(6)
  // Relaciones
  ordenes           ordenes             @relation(fields: [orden_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  confecciones      confecciones?       @relation(fields: [confeccion_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario_reporta   usuarios?           @relation("incidencia_reporta", fields: [reportado_por], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario_resuelve  usuarios?           @relation("incidencia_resuelve", fields: [asignado_a], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([orden_id], map: "idx_incidencias_orden")
  @@index([tipo], map: "idx_incidencias_tipo")
  @@index([severidad], map: "idx_incidencias_severidad")
  @@index([resuelto], map: "idx_incidencias_resuelto")
  @@index([fecha_reporte(sort: Desc)], map: "idx_incidencias_fecha")
  @@schema("public")
}

// ============================================================
//  ESTADOS DE PRODUCCIÓN
//  Trackea el tiempo que pasa un pedido en cada etapa
// ============================================================
model estados_produccion {
  id                BigInt          @id @default(autoincrement())
  orden_id          BigInt
  etapa             EtapaProduccion
  // Control de tiempos
  iniciado_en       DateTime        @default(now()) @db.Timestamptz(6)
  completado_en     DateTime?       @db.Timestamptz(6)
  duracion_minutos  Int?            // Calculado al completar
  // Responsable de la etapa
  usuario_id        BigInt?
  observaciones     String?
  // Estado actual
  activo            Boolean         @default(true)  // true = en curso, false = completado/saltado
  // Auditoría
  created_at        DateTime        @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?       @default(now()) @db.Timestamptz(6)
  // Relaciones
  ordenes           ordenes         @relation(fields: [orden_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuarios          usuarios?       @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([orden_id], map: "idx_estados_prod_orden")
  @@index([etapa], map: "idx_estados_prod_etapa")
  @@index([activo], map: "idx_estados_prod_activo")
  @@index([iniciado_en(sort: Desc)], map: "idx_estados_prod_inicio")
  @@schema("public")
}

// ============================================================
//  FEEDBACK DE CLIENTE
//  Satisfacción post-entrega vinculado a orden y cliente
// ============================================================
model feedback_cliente {
  id                BigInt      @id @default(autoincrement())
  orden_id          BigInt
  cliente_id        BigInt
  // Puntuación 1-5
  puntuacion        Int         // 1 = muy insatisfecho, 5 = muy satisfecho
  // Dimensiones opcionales de evaluación
  calidad_producto  Int?        // 1-5
  tiempo_entrega    Int?        // 1-5
  atencion_personal  Int?       // 1-5
  // Comentarios
  comentarios       String?
  recomendaria      Boolean?    // ¿Recomendaría el servicio?
  // Metadata
  enviado_en        DateTime?   @db.Timestamptz(6)  // Cuándo se envió la encuesta
  respondido_en     DateTime?   @db.Timestamptz(6)  // Cuándo respondió el cliente
  canal             String?     @db.VarChar(50)      // email, whatsapp, presencial, web
  // Auditoría
  created_at        DateTime    @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?   @default(now()) @db.Timestamptz(6)
  // Relaciones
  ordenes           ordenes     @relation(fields: [orden_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  clientes          clientes    @relation(fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([orden_id], map: "idx_feedback_orden")
  @@index([cliente_id], map: "idx_feedback_cliente")
  @@index([puntuacion], map: "idx_feedback_puntuacion")
  @@schema("public")
}

// ============================================================
//  FICHAS TÉCNICAS (con RLS — requieren setup adicional)
// ============================================================

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model detalle_ficha_insumos {
  id               BigInt           @id @default(autoincrement())
  id_ficha         BigInt?
  id_insumo        BigInt?
  consumo_unitario Float?           @db.Real
  merma_permitida  Float?           @db.Real
  created_at       DateTime         @default(now()) @db.Timestamptz(6)
  fichas_tecnicas  fichas_tecnicas? @relation(fields: [id_ficha], references: [id], onDelete: NoAction, onUpdate: NoAction)
  insumo           insumo?          @relation(fields: [id_insumo], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ficha_medidas {
  id              BigInt           @id @default(autoincrement())
  id_ficha        BigInt?
  punto_medida    String?          @db.VarChar
  talla           String?          @db.VarChar
  valor_cm        Float?           @db.Real
  tolerancia      Float?           @db.Real
  created_at      DateTime         @default(now()) @db.Timestamptz(6)
  fichas_tecnicas fichas_tecnicas? @relation(fields: [id_ficha], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model fichas_tecnicas {
  id                    BigInt                  @id @default(autoincrement())
  id_producto           BigInt?
  version               String?                 @db.VarChar
  descripcion_detallada String?
  sam_total             Float?                  @db.Real
  costo_estimado        Float?                  @db.Real
  imagen_geometral      String?                 @db.VarChar
  estado                estado_ficha?
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  detalle_ficha_insumos detalle_ficha_insumos[]
  ficha_medidas         ficha_medidas[]
  productos             productos?              @relation(fields: [id_producto], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("fichas-tecnicas")
  @@schema("public")
}


model insumo {
  id                     BigInt                   @id(map: "inventario_pkey") @default(autoincrement())
  nombre                 String
  tipo                   TipoInsumo
  categoria_insumo       CategoriaInsumo          @default(otro)  // Para alertas de dashboard
  unidad_medida          UnidadMedida             @default(unidades)
  stock_actual           Int                      @default(0)
  stock_minimo           Int                      @default(10)
  stock_maximo           Int?                     // Límite superior para overstock alerts
  precio_unitario        Decimal?                 @db.Decimal(10, 2)
  created_at             DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at             DateTime?                @default(now()) @db.Timestamptz(6)
  proveedor_id           BigInt?                  // Vinculo al proveedor de este insumo
  ubicacion_almacen      String?                  @db.VarChar(100)  // Estante / zona
  alerta_bajo_stock      Boolean?                 @default(true)    // Activa alertas de stock mínimo
  // Relaciones
  proveedores            proveedores?             @relation(fields: [proveedor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  detalle_ficha_insumos  detalle_ficha_insumos[]
  movimientos_inventario movimientos_inventario[]

  @@index([categoria_insumo], map: "idx_insumos_categoria")
  @@index([stock_actual], map: "idx_insumos_stock")
  @@index([proveedor_id], map: "idx_insumos_proveedor")
  @@schema("public")
}

model movimientos_inventario {
  id                BigInt             @id(map: "lista_materiales_pkey") @default(autoincrement())
  producto_id       BigInt?
  insumo_id         BigInt?
  cantidad          Float?
  motivo            String?
  usuario_id        BigInt?
  tipo_movimiento   TipoMovimiento?
  created_at        DateTime           @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?          @default(now()) @db.Timestamptz(6)
  // Campos de valorización para auditoría contable
  costo_unitario    Decimal?           @db.Decimal(12, 2)
  stock_anterior    Float?
  stock_posterior   Float?
  // Campos de referencia vincular a Orden, Compra o Ajuste
  referencia_tipo   String?            @db.VarChar(50)  // 'ORDEN', 'COMPRA', 'AJUSTE', 'VENTA'
  referencia_id     BigInt?
  // Relaciones
  insumo            insumo?            @relation(fields: [insumo_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productos         productos?         @relation(fields: [producto_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuarios          usuarios?          @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([referencia_tipo, referencia_id], map: "idx_movimientos_referencia")
  @@index([created_at(sort: Desc)], map: "idx_movimientos_fecha")
  @@schema("public")
}

model reservas_stock {
  id                 BigInt             @id @default(autoincrement())
  variante_id        BigInt
