// ============================================================
//  ABASTECIMIENTO — Proveedores y Órdenes de Compra
// ============================================================

model proveedores {
  id                    BigInt      @id @default(autoincrement())
  ruc                   String      @unique @db.VarChar(11)
  razon_social          String      @db.VarChar(200)
  contacto              String      @db.VarChar(150)
  telefono              String      @db.VarChar(20)
  email                 String      @unique @db.VarChar(150)
  direccion             String      @db.VarChar(255)
  categoria_suministro  String      @db.VarChar(100)  // telas, avios, empaque, maquinaria, etc.
  estado                String      @default("activo") @db.VarChar(20)  // activo, inactivo
  created_at            DateTime    @default(now()) @db.Timestamptz(6)
  updated_at            DateTime    @default(now()) @db.Timestamptz(6)
  // Relaciones
  insumos               insumo[]
  ordenes_compra        ordenes[]

  @@index([estado], map: "idx_proveedores_estado")
  @@index([categoria_suministro], map: "idx_proveedores_categoria")
  @@index([razon_social], map: "idx_proveedores_razon")
  @@schema("public")
}
