  updated_at              DateTime?               @default(now()) @db.Timestamptz(6)
  cotizaciones_proveedor  cotizaciones_proveedor? @relation(fields: [cotizacion_proveedor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                   users?                  @relation(fields: [creado_por], references: [id], onDelete: NoAction, onUpdate: NoAction)
  proveedores             proveedores             @relation(fields: [proveedor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ordenes_compra_items    ordenes_compra_items[]

  @@index([estado], map: "idx_ordenes_compra_est")
  @@index([proveedor_id], map: "idx_ordenes_compra_prov")
  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ordenes_compra_items {
  id                BigInt         @id @default(autoincrement())
  orden_compra_id   BigInt
  material_id       BigInt?
  insumo_id         BigInt?
  cantidad_pedida   Decimal        @db.Decimal(12, 2)
  cantidad_recibida Decimal        @default(0) @db.Decimal(12, 2)
  precio_unitario   Decimal        @db.Decimal(12, 2)
  subtotal          Decimal?       @default(dbgenerated("(cantidad_pedida * precio_unitario)")) @db.Decimal(12, 2)
  notas             String?
  insumo            insumo?        @relation(fields: [insumo_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  materiales        materiales?    @relation(fields: [material_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ordenes_compra    ordenes_compra @relation(fields: [orden_compra_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

