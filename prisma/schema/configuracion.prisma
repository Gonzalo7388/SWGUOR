// ============================================================
//  CONFIGURACIÓN DEL SISTEMA
//  Almacena ajustes generales de la empresa
// ============================================================

model configuracion_sistema {
  id          BigInt    @id @default(autoincrement())
  clave       String    @unique @db.VarChar(100)
  valor       String    @db.Text
  categoria   String    @default("general") @db.VarChar(50)
  descripcion String?   @db.VarChar(255)
  tipo_dato   String    @default("string") @db.VarChar(20) // string, number, boolean, json
  updated_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_by  String?   @db.Uuid

  @@index([categoria], map: "idx_config_categoria")
  @@schema("public")
}
