model cotizaciones {
  id                   BigInt             @id @default(autoincrement())
  numero               String             @unique
  cliente_id           String?            @db.Uuid
  estado               String             @default("borrador")
  subtotal             Decimal            @default(0) @db.Decimal(12, 2)
  descuento_pct        Decimal            @default(0) @db.Decimal(5, 2)
  descuento_monto      Decimal            @default(0) @db.Decimal(12, 2)
  igv                  Decimal            @default(0) @db.Decimal(12, 2)
  total                Decimal            @default(0) @db.Decimal(12, 2)
  notas                String?
  valida_hasta         DateTime           @db.Date
  pdf_url              String?
  convertida_en        BigInt?
  origen_cotizacion_id BigInt?
  created_at           DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?          @default(now()) @db.Timestamptz(6)
  cotizacion_items     cotizacion_items[]
  clientes             clientes?          @relation(fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ordenes              ordenes?           @relation(fields: [convertida_en], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cotizaciones         cotizaciones?      @relation("cotizacionesTocotizaciones", fields: [origen_cotizacion_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_cotizaciones   cotizaciones[]     @relation("cotizacionesTocotizaciones")
  reservas_stock       reservas_stock[]

  @@schema("public")
}

model cotizacion_items {
  id                 BigInt              @id @default(autoincrement())
  cotizacion_id      BigInt
  producto_id        BigInt
  variante_id        BigInt?
  precio_snapshot    Decimal             @db.Decimal(10, 2)
  cantidad           Int
  talla              String?
  color              String?
  subtotal           Decimal             @db.Decimal(12, 2)
  moq_aplicado       Int                 @default(400)
  cotizaciones       cotizaciones        @relation(fields: [cotizacion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  productos          productos           @relation(fields: [producto_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  variantes_producto variantes_producto? @relation(fields: [variante_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model ordenes {
  id             BigInt           @id @default(autoincrement())
  user_id        BigInt?
  cliente_id     String?          @db.Uuid
  subtotal       Decimal          @default(0) @db.Decimal(12, 2)
  impuestos      Decimal          @default(0) @db.Decimal(12, 2)
  total          Decimal          @default(0) @db.Decimal(12, 2)
  estado         EstadoOrden?     @default(solicitado)
  metodo_pago    MetodoPago?
  payment_id     String?
  notas_internas String?
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?        @default(now()) @db.Timestamptz(6)
  comprobantes   comprobantes[]
  cotizaciones   cotizaciones[]
  detalles_orden detalles_orden[]
  cliente        clientes?        @relation(fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users          usuarios?        @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pedidos        pedidos[]
  reservas_stock reservas_stock[]
  ventas         ventas[]

  @@schema("public")
}

model detalles_orden {
  id              BigInt          @id @default(autoincrement())
  orden_id        BigInt
  producto_id     BigInt
  cantidad        Int
  precio_unitario Decimal         @db.Decimal(12, 2)
  subtotal        Decimal         @db.Decimal(12, 2)
  talla           TallaProductos?
  color           String?
  ordenes         ordenes         @relation(fields: [orden_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productos       productos       @relation(fields: [producto_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "detalles_orden_producto_fkey")

  @@schema("public")
}

model ventas {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orden_id           BigInt
  vendedor_id        BigInt?
  subtotal           Decimal          @default(0) @db.Decimal(12, 2)
  impuestos          Decimal          @default(0) @db.Decimal(12, 2)
  total              Decimal          @default(0) @db.Decimal(12, 2)
  metodo_pago        MetodoPago?
  numero_comprobante String?
  created_at         DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?        @default(now()) @db.Timestamptz(6)
  tipo_comprobante   TipoComprobante?
  vendedor           usuarios?        @relation(fields: [vendedor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ordenes            ordenes          @relation(fields: [orden_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_ventas_fecha_pago")
  @@index([orden_id], map: "idx_ventas_orden_link")
  @@schema("public")
}

model comprobantes {
  id          BigInt    @id @default(autoincrement())
  orden_id    BigInt
  tipo        String
  serie       String
  correlativo String
  pdf_url     String?
  xml_url     String?
  emitido_en  DateTime? @default(now()) @db.Timestamptz(6)
  ordenes     ordenes   @relation(fields: [orden_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}
