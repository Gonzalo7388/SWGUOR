model categorias {
  id               BigInt             @id @default(autoincrement())
  nombre           String
  descripcion      String?
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  orden            BigInt?
  activo           Boolean?
  imagen           String?
  updated_at       DateTime?          @default(now()) @db.Timestamptz(6)

  productos        productos[]
  reglas_descuento reglas_descuento[]

  @@schema("public")
}

model productos {
  id                  BigInt         @id @default(autoincrement())
  nombre              String
  descripcion         String?
  imagen              String?
  precio              Float
  stock               Int            @default(0)
  estado              EstadoProducto @default(activo)
  sku                 String         @unique
  destacado           Boolean?       @default(false)
  categoria_id        BigInt?
  moq                 Int            @default(400)
  colores_disponibles Json?          @default("[]")
  tallas_disponibles  Json?          @default("[]")
  fichas_tecnicas_id  BigInt?
  reglas_descuento    Json?
  created_at          DateTime       @default(now()) @db.Timestamptz(6)
  updated_at          DateTime       @db.Timestamptz(6)

  // Relaciones
  cotizacion_items       cotizacion_items[]
  movimientos_inventario movimientos_inventario[]
  pedido_items           pedido_items[]
  precio_historico       precio_historico[]
  categorias             categorias?              @relation(fields: [categoria_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ficha_tecnica_rel      fichas_tecnicas?         @relation("producto_ficha_principal", fields: [fichas_tecnicas_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  variantes_producto     variantes_producto[]
  ordenes_produccion     ordenes_produccion[]

  @@index([estado], map: "idx_productos_estado")
  @@index([nombre], map: "idx_productos_nombre")
  @@schema("public")
}

model variantes_producto {
  id               BigInt             @id @default(autoincrement())
  producto_id      BigInt
  nombre           String             @db.VarChar(100)
  color            ColorPrenda
  talla            TallaProductos
  estado           EstadoProducto     @default(activo)
  precio_adicional Decimal            @default(0.00) @db.Decimal(10, 2)
  stock_adicional  Int                @default(0)
  sku              String             @unique(map: "unique_variant_sku") @db.VarChar(100)
  imagen_url       String?
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?          @default(now()) @db.Timestamptz(6)

  cotizacion_items cotizacion_items[]
  pedido_items     pedido_items[]
  reservas_stock   reservas_stock[]
  productos        productos          @relation(fields: [producto_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([producto_id, talla, color], map: "unique_producto_talla_color")
  @@index([producto_id], map: "idx_variantes_producto_id")
  @@index([talla, color], map: "idx_variantes_busqueda_cliente", where: raw("(estado = 'activo'::\"EstadoProducto\")"))
  @@schema("public")
}

model precio_historico {
  id            BigInt    @id @default(autoincrement())
  producto_id   BigInt
  precio        Decimal   @db.Decimal(10, 2)
  motivo        String?
  vigente_desde DateTime  @default(now()) @db.Timestamptz(6)
  vigente_hasta DateTime? @db.Timestamptz(6)
  creado_por    String?   @db.Uuid
  
  users         users?    @relation(fields: [creado_por], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productos     productos @relation(fields: [producto_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model reglas_descuento {
  id               BigInt         @id @default(autoincrement())
  nombre           String
  cantidad_min     Int            @default(400)
  monto_min_compra Decimal?       @db.Decimal(12, 2)
  tipo_beneficio   TipoBeneficio
  valor_descuento  Decimal        @db.Decimal(10, 2)
  fecha_inicio     DateTime       @db.Timestamptz(6)
  fecha_fin        DateTime       @db.Timestamptz(6)
  categoria_id     BigInt?
  activo           Boolean?       @default(true)
  tipo_conteo      TipoConteo
  // Relaciones
  categorias       categorias?    @relation(fields: [categoria_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cotizaciones     cotizaciones[]

  @@index([activo], map: "idx_reglas_activo")
  @@index([fecha_inicio, fecha_fin], map: "idx_reglas_vigencia")
  @@schema("public")
}
