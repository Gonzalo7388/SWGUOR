model categorias {
  id          BigInt      @id @default(autoincrement())
  nombre      String      @unique
  descripcion String?
  created_at  DateTime    @default(now())
  orden       BigInt?
  activo      Boolean?
  imagen      String?
  updated_at  DateTime?   @default(now()) @db.Timestamp(6)
  productos   productos[]

  @@schema("public")
}

model productos {
  id                     BigInt                   @id @default(autoincrement())
  nombre                 String
  descripcion            String?
  created_at             DateTime                 @default(now())
  imagen                 String?
  precio                 Float
  stock                  Int                      @default(0)
  updated_at             DateTime
  estado                 EstadoProducto           @default(activo)
  sku                    String                   @unique
  destacado              Boolean?                 @default(false)
  categoria_id           BigInt?
  cotizacion_items       cotizacion_items[]
  detalles_orden         detalles_orden[]
  movimientos_inventario movimientos_inventario[]
  pedidos                pedidos[]
  precio_historico       precio_historico[]
  categorias             categorias?              @relation(fields: [categoria_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  variantes_producto     variantes_producto[]

  @@index([estado], map: "idx_productos_estado")
  @@index([nombre], map: "idx_productos_nombre")
  @@schema("public")
}

model variantes_producto {
  id               BigInt             @id @default(autoincrement())
  producto_id      BigInt
  nombre           String             @db.VarChar(100)
  color            ColorPrenda
  talla            TallaProductos
  estado           EstadoProducto     @default(activo)
  precio_adicional Decimal            @default(0.00) @db.Decimal(10, 2)
  stock_adicional  Int                @default(0)
  sku              String             @unique(map: "unique_variant_sku") @db.VarChar(100)
  imagen_url       String?
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?          @default(now()) @db.Timestamptz(6)
  cotizacion_items cotizacion_items[]
  reservas_stock   reservas_stock[]
  productos        productos          @relation(fields: [producto_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([producto_id, talla, color], map: "unique_producto_talla_color")
  @@index([producto_id], map: "idx_variantes_producto_id")
  @@schema("public")
}

model precio_historico {
  id            BigInt    @id @default(autoincrement())
  producto_id   BigInt
  precio        Decimal   @db.Decimal(10, 2)
  motivo        String?
  vigente_desde DateTime  @default(now()) @db.Timestamptz(6)
  vigente_hasta DateTime? @db.Timestamptz(6)
  creado_por    String?   @db.Uuid
  users         users?    @relation(fields: [creado_por], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productos     productos @relation(fields: [producto_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model reglas_descuento {
  id            BigInt  @id @default(autoincrement())
  nombre        String
  cantidad_min  Int
  cantidad_max  Int?
  descuento_pct Decimal @db.Decimal(5, 2)
  aplica_a      String? @default("global")

  @@schema("public")
}
