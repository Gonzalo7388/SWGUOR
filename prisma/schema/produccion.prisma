model pedidos {
  id                       BigInt           @id @default(autoincrement())
  fecha_pedido             DateTime?        @default(now()) @db.Timestamptz(6)
  estado                   EstadoPedido?    @default(pendiente)
  prioridad                PrioridadPedido? @default(normal)
  created_by               String?          @default(dbgenerated("auth.uid()")) @db.Uuid
  created_at               DateTime         @default(now()) @db.Timestamptz(6)
  updated_at               DateTime?        @db.Timestamptz(6)
  updated_by               String?          @default(dbgenerated("auth.uid()")) @db.Uuid
  orden_id                 BigInt?
  producto_id              BigInt?
  talla                    TallaProductos?
  cantidad                 Int?             @default(1)
  precio_unitario          Decimal?         @default(0) @db.Decimal(12, 2)
  nombre_producto_snapshot String?
  especificaciones         Json?
  despachos                despachos[]
  ordenes                  ordenes?         @relation(fields: [orden_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productos                productos?       @relation(fields: [producto_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model confecciones {
  id            BigInt           @id @default(autoincrement())
  pedido_id     BigInt
  taller_id     BigInt
  estado        EstadoConfeccion @default(corte)
  fecha_inicio  DateTime
  fecha_fin     DateTime?
  observaciones String?
  created_at    DateTime         @default(now())
  updated_at    DateTime
  talleres      talleres         @relation(fields: [taller_id], references: [id])

  @@schema("public")
}

model talleres {
  id           BigInt              @id @default(autoincrement())
  nombre       String
  direccion    String
  telefono     String
  email        String?             @unique
  created_at   DateTime            @default(now())
  updated_at   DateTime
  ruc          String              @unique
  contacto     String
  especialidad EspecialidadTaller?
  estado       EstadoTaller        @default(activo)
  confecciones confecciones[]

  @@schema("public")
}
model despachos {
  id                BigInt         @id @default(autoincrement())
  pedido_id         BigInt
  fecha_despacho    DateTime
  created_at        DateTime       @default(now())
  direccion_entrega String
  fecha_entrega     DateTime?
  updated_at        DateTime
  usuario_id        BigInt
  estado            EstadoDespacho @default(pendiente)
  pedidos           pedidos        @relation(fields: [pedido_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuarios          usuarios       @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}
