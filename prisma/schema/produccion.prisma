model confecciones {
  id                     BigInt                   @id @default(autoincrement())
  pedido_id              BigInt
  taller_id              BigInt
  estado                 EstadoConfeccion         @default(pendiente)
  fecha_inicio           DateTime                 @db.Timestamptz(6)
  fecha_fin              DateTime?                @db.Timestamptz(6)
  observaciones          String?
  created_at             DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                 @default(now()) @db.Timestamptz(6)
  responsable_id         BigInt?
  prenda                 String                   @default("")
  cantidad               Int                      @default(1)
  costo_unitario         Decimal?                 @db.Decimal(12, 2)
  fecha_entrega          DateTime?                @db.Date
  prioridad              String                   @default("media")
  notas                  String?

  pedido                 pedidos                  @relation(fields: [pedido_id], references: [id])
  taller                 talleres                 @relation(fields: [taller_id], references: [id])
  responsable            usuarios?                @relation(fields: [responsable_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  incidencias_taller     incidencias_taller[]
  ordenes                ordenes_produccion[]
  seguimiento_confeccion seguimiento_confeccion[]

  @@index([pedido_id], map: "idx_confecciones_pedido")
  @@index([responsable_id], map: "idx_confecciones_responsable")
  @@schema("public")
}

model talleres {
  id                 BigInt              @id @default(autoincrement())
  nombre             String
  direccion          String
  telefono           String
  email              String?             @unique
  ruc                String              @unique
  contacto           String
  especialidad       EspecialidadTaller?
  estado             EstadoTaller        @default(activo)
  created_at         DateTime            @default(now()) @db.Timestamptz(6)
  updated_at         DateTime            @default(now()) @db.Timestamptz(6)

  confecciones       confecciones[]
  ordenes_produccion ordenes_produccion[]

  @@schema("public")
}

model despachos {
  id                BigInt         @id @default(autoincrement())
  pedido_id         BigInt
  fecha_despacho    DateTime
  created_at        DateTime       @default(now())
  direccion_entrega String
  fecha_entrega     DateTime?
  updated_at        DateTime       @default(now())
  usuario_id        BigInt
  estado            EstadoDespacho @default(pendiente)
  pedido            pedidos        @relation(fields: [pedido_id], references: [id])
  usuario           usuarios       @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([pedido_id], map: "idx_despachos_pedido")
  @@schema("public")
}

model seguimiento_confeccion {
  id              BigInt            @id @default(autoincrement())
  confeccion_id   BigInt?
  estado_anterior EstadoConfeccion?
  estado_nuevo    EstadoConfeccion?
  notas           String?
  responsable_id  BigInt?
  created_at      DateTime?         @default(now()) @db.Timestamptz(6)

  confecciones    confecciones?     @relation(fields: [confeccion_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuarios        usuarios?         @relation(fields: [responsable_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([confeccion_id], map: "idx_seg_confeccion_id")
  @@schema("public")
}

model seguimiento_produccion {
  id               BigInt              @id @default(autoincrement())
  orden_id         BigInt
  etapa            EtapaProduccion
  iniciado_en      DateTime            @default(now()) @db.Timestamptz(6)
  completado_en    DateTime?           @db.Timestamptz(6)
  duracion_minutos Int?
  usuario_id       BigInt?
  observaciones    String?
  activo           Boolean            @default(true)
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  
  ordenes          ordenes_produccion @relation(fields: [orden_id], references: [id], onDelete: Cascade)
  usuarios         usuarios?          @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([etapa], map: "idx_seg_prod_etapa")
  @@index([activo], map: "idx_seg_prod_activo")
  @@index([iniciado_en(sort: Desc)], map: "idx_seg_prod_inicio")
  @@index([orden_id])
  @@schema("public")
}

model incidencias_taller {
  id               BigInt              @id @default(autoincrement())
  orden_id         BigInt
  confeccion_id    BigInt?
  tipo             TipoIncidencia
  severidad        SeveridadIncidencia @default(media)
  descripcion      String
  reportado_por    BigInt?
  asignado_a       BigInt?
  fecha_reporte    DateTime            @default(now()) @db.Timestamptz(6)
  fecha_resolucion DateTime?           @db.Timestamptz(6)
  resuelto         Boolean             @default(false)
  solucion         String?
  impacto_horas    Float?
  foto_url         String?             @db.VarChar(500)
  created_at       DateTime            @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?           @default(now()) @db.Timestamptz(6)
  ordenes          ordenes             @relation(fields: [orden_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  confecciones     confecciones?       @relation(fields: [confeccion_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario_reporta  usuarios?           @relation("incidencia_reporta", fields: [reportado_por], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario_resuelve usuarios?           @relation("incidencia_resuelve", fields: [asignado_a], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([orden_id], map: "idx_incidencias_orden")
  @@index([tipo], map: "idx_incidencias_tipo")
  @@index([severidad], map: "idx_incidencias_severidad")
  @@index([resuelto], map: "idx_incidencias_resuelto")
  @@index([fecha_reporte(sort: Desc)], map: "idx_incidencias_fecha")
  @@schema("public")
}

model detalle_ficha_insumos {
  id               BigInt           @id @default(autoincrement())
  id_ficha         BigInt?
  id_insumo        BigInt?
  consumo_unitario Float?           @db.Real
  merma_permitida  Float?           @db.Real
  created_at       DateTime         @default(now()) @db.Timestamptz(6)
  
  fichas_tecnicas  fichas_tecnicas? @relation(fields: [id_ficha], references: [id], onDelete: NoAction, onUpdate: NoAction)
  insumo           insumo?          @relation(fields: [id_insumo], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model ficha_medidas {
  id              BigInt           @id @default(autoincrement())
  id_ficha        BigInt?
  punto_medida    String?          @db.VarChar
  talla           String?          @db.VarChar
  valor_cm        Float?           @db.Real
  tolerancia      Float?           @db.Real
  created_at      DateTime         @default(now()) @db.Timestamptz(6)
  fichas_tecnicas fichas_tecnicas? @relation(fields: [id_ficha], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model fichas_tecnicas {
  id                    BigInt                  @id @default(autoincrement())
  id_producto           BigInt?
  version               String?                 @db.VarChar
  descripcion_detallada String?
  sam_total             Float?                  @db.Real
  costo_estimado        Float?                  @db.Real
  imagen_geometral      String?                 @db.VarChar
  estado                EstadoFicha?            @default(borrador)
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  ficha_url             String?                 
  
  productos_rel         productos[]             @relation("producto_ficha_principal")
  medidas               ficha_medidas[]
  insumos               detalle_ficha_insumos[]
  ordenes_produccion    ordenes_produccion[]

  @@schema("public")
}

model ordenes_produccion {
  id                  BigInt                   @id @default(autoincrement())
  producto_id         BigInt
  taller_id           BigInt
  ficha_id            BigInt
  pedido_id           BigInt
  estado              String                   @default("pendiente")
  cantidad_solicitada Int                      @default(0)
  fecha_entrega       DateTime?                @db.Date
  notas               String?
  creado_por          BigInt?
  notificado_at       DateTime?                @db.Timestamptz(6)
  email_enviado_at    DateTime?                @db.Timestamptz(6)
  created_at          DateTime?                @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?                @default(now()) @db.Timestamptz(6)

  pedido_rel          pedidos?                 @relation(fields: [pedido_id], references: [id])
  producto            productos?               @relation(fields: [producto_id], references: [id])
  taller              talleres?                @relation(fields: [taller_id], references: [id])
  ficha               fichas_tecnicas?         @relation(fields: [ficha_id], references: [id])
  confecciones        confecciones[]
  seguimientos        seguimiento_produccion[]

  @@index([producto_id])
  @@index([taller_id])
  @@index([estado])
  @@schema("public")
}