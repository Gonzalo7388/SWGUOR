model pedidos {
  id             BigInt           @id @default(autoincrement())
  cliente_id     BigInt?
  estado         EstadoPedido?    @default(pendiente)
  prioridad      PrioridadPedido? @default(normal)
  notas_cliente  String?
  created_by     String?          @default(dbgenerated("uid()")) @db.Uuid
  created_at     DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?        @default(now()) @db.Timestamptz(6)
  notas_pedido   String?
  total_estimado Decimal?         @default(0) @db.Decimal(12, 2)
  total_unidades Int              @default(0)
  moq_aplicado   Int              @default(400)
  cotizaciones   cotizaciones[]
  pedido_items   pedido_items[]
  clientes       clientes?        @relation(fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users          users?           @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model confecciones {
  id            BigInt           @id @default(autoincrement())
  pedido_id     BigInt
  taller_id     BigInt
  estado        EstadoConfeccion @default(corte)
  fecha_inicio  DateTime         @db.Timestamptz(6)
  fecha_fin     DateTime?        @db.Timestamptz(6)
  observaciones String?
  created_at    DateTime         @default(now()) @db.Timestamptz(6)
  updated_at    DateTime         @db.Timestamptz(6)
  talleres      talleres         @relation(fields: [taller_id], references: [id])

  @@schema("public")
}

model talleres {
  id           BigInt              @id @default(autoincrement())
  nombre       String
  direccion    String
  telefono     String
  email        String?             @unique
  created_at   DateTime            @default(now()) @db.Timestamptz(6)
  updated_at   DateTime            @db.Timestamptz(6)
  ruc          String              @unique
  contacto     String
  especialidad EspecialidadTaller?
  estado       EstadoTaller        @default(activo)
  confecciones confecciones[]

  @@schema("public")
}

model despachos {
  id                BigInt         @id @default(autoincrement())
  pedido_id         BigInt
  fecha_despacho    DateTime
  created_at        DateTime       @default(now())
  direccion_entrega String
  fecha_entrega     DateTime?
  updated_at        DateTime
  usuario_id        BigInt
  estado            EstadoDespacho @default(pendiente)
  usuarios          usuarios       @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}


/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model detalle_ficha_insumos {
  id               BigInt           @id @default(autoincrement())
  id_ficha         BigInt?
  id_insumo        BigInt?
  consumo_unitario Float?           @db.Real
  merma_permitida  Float?           @db.Real
  created_at       DateTime         @default(now()) @db.Timestamptz(6)
  fichas_tecnicas  fichas_tecnicas? @relation(fields: [id_ficha], references: [id], onDelete: NoAction, onUpdate: NoAction)
  insumo           insumo?          @relation(fields: [id_insumo], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ficha_medidas {
  id              BigInt           @id @default(autoincrement())
  id_ficha        BigInt?
  punto_medida    String?          @db.VarChar
  talla           String?          @db.VarChar
  valor_cm        Float?           @db.Real
  tolerancia      Float?           @db.Real
  created_at      DateTime         @default(now()) @db.Timestamptz(6)
  fichas_tecnicas fichas_tecnicas? @relation(fields: [id_ficha], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model fichas_tecnicas {
  id                    BigInt                  @id @default(autoincrement())
  id_producto           BigInt?
  version               String?                 @db.VarChar
  descripcion_detallada String?
  sam_total             Float?                  @db.Real
  costo_estimado        Float?                  @db.Real
  imagen_geometral      String?                 @db.VarChar
  estado                estado_ficha?
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  detalle_ficha_insumos detalle_ficha_insumos[]
  ficha_medidas         ficha_medidas[]
  productos             productos?              @relation(fields: [id_producto], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("fichas-tecnicas")
  @@schema("public")
}