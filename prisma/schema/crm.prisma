model clientes {
  id                  BigInt                @id(map: "Clientes_pkey") @default(autoincrement())
  
  // Identificación Básica
  tipo_documento      String?               @db.VarChar(20) // RUC 10, RUC 20, DNI, CE
  ruc                 String                @unique @db.VarChar(20) 
  
  // Persona Natural (RUC 10 / DNI)
  nombre              String?               @db.VarChar(100)
  apellido_paterno    String?               @db.VarChar(100)
  apellido_materno    String?               @db.VarChar(100)
  
  // Persona Jurídica (RUC 20)
  razon_social        String?               @db.VarChar(255)
  nombre_comercial    String?               @db.VarChar(255)
  
  // Contacto y Ubicación
  email               String?               @db.VarChar(150)
  telefono            String?               @db.VarChar(50)
  direccion_fiscal    String?               @db.VarChar(255) // La dirección principal de la ficha RUC
  pais                String?               @default("Peru") @db.VarChar(50)
  
  // Clasificación Comercial (Basado en tu Excel)
  estado_comercial    String?               @default("Activo") @db.VarChar(50) // Activo, Inactivo, Prospecto
  lista_precios       String?               @db.VarChar(50) 
  sector              String?               @default("General") @db.VarChar(50)
  sub_sector          String?               @default("General") @db.VarChar(50)
  categoria_cliente   String?               @default("General") @db.VarChar(50)
  codigo_cliente      String?               @unique @db.VarChar(50)
  
  // Configuración de Ventas (Para automatizar Cotizaciones)
  moneda_defecto      String?               @db.VarChar(20) // Soles, Dólares Americanos, Euros
  forma_pago_defecto  String?               @db.VarChar(100) // Contado, Crédito 30 días, etc.
  metodo_comercial    String?               @db.VarChar(100) // Despachar->Facturar, Facturar->Despachar
  tipo_pedido_defecto String?               @db.VarChar(50) // LOCAL, EXPORTACIÓN
  impuesto_defecto    String?               @default("IGV") @db.VarChar(20)

  // Auditoría y Estado
  activo              EstadoCliente?        @default(activo)
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @default(now()) @db.Timestamptz(6)

  // Relaciones
  usuario_id          BigInt?               @unique
  usuarios            usuarios?             @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cotizaciones        cotizaciones[]
  direcciones_cliente direcciones_cliente[]
  ordenes             ordenes[]
  pedidos             pedidos[]
  feedback_cliente    feedback_cliente[]

  @@schema("public")
}

model direcciones_cliente {
  id           BigInt    @id @default(autoincrement())
  cliente_id   BigInt
  alias        String
  direccion    String
  ciudad       String?
  departamento String?
  es_principal Boolean?  @default(false)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  clientes     clientes  @relation(fields: [cliente_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

model usuarios {
  id                     BigInt                   @id @default(autoincrement())
  email                  String                   @unique
  nombre_completo        String
  telefono               BigInt?
  estado                 EstadoUsuario?           @default(activo)
  rol                    RolPersonal?
  created_at             DateTime?                @default(now()) @db.Timestamptz(6)
  updated_at             DateTime?                @default(now()) @db.Timestamptz(6)
  ultimo_acceso          DateTime?                @db.Timestamptz(6)
  created_by             String?                  @db.Uuid
  auth_id                String?                  @unique @db.Uuid
  // Relaciones
  clientes               clientes?
  despachos              despachos[]
  movimientos_inventario movimientos_inventario[]
  pagos_orden            pagos_orden[]            @relation("usuario_pagos")
  ventas                 ventas[]
  personal_interno       personal_interno[]
  users                  users?                   @relation(fields: [auth_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  // Producción
  confecciones           confecciones[]
  estados_produccion     estados_produccion[]
  incidencias_reportadas incidencias_taller[]     @relation("incidencia_reporta")
  incidencias_resueltas  incidencias_taller[]     @relation("incidencia_resuelve")

  @@schema("public")
}


model personal_interno {
  id              BigInt       @id @default(autoincrement())
  usuario_id      BigInt?
  dni             BigInt?
  nombre_completo String?
  cargo           RolPersonal?
  estado          Boolean?
  fecha_ingreso   DateTime?    @db.Date
  created_at      DateTime?    @default(now()) @db.Timestamp(6)
  updated_at      DateTime?    @default(now()) @db.Timestamp(6)
  usuarios        usuarios?    @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}
